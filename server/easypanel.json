{
  "$schema": "https://easypanel.io/schema.json",
  "name": "illumistream-server",
  "services": {
    "app": {
      "type": "app",
      "source": {
        "type": "dockerfile",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "replicas": 1,
        "resources": {
          "limits": {
            "cpus": 2,
            "memory": "2G"
          }
        }
      },
      "env": {
        "NODE_ENV": "production",
        "PORT": "3001"
      },
      "ports": [
        {
          "internal": 3001,
          "protocol": "http"
        }
      ],
      "domains": [
        {
          "name": "stream.${DOMAIN}"
        }
      ]
    }
  }
}
